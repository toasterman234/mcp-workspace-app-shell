{
  "name": "mcp-quant-mcp-workspace",
  "private": true,
  "version": "0.1.0",
  "description": "Cross-host MCP workspace shell for quant research (MCPHub-only, mock + live)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node ./node_modules/typescript/bin/tsc -b && node ./node_modules/vite/bin/vite.js build",
    "lint": "node ./node_modules/eslint/bin/eslint.js .",
    "preview": "vite preview",
    "app:server:install": "npm --prefix ./apps/chatgpt-app-server install",
    "app:server:build-widget": "npm --prefix ./apps/chatgpt-app-server run build:widget",
    "app:server:dev": "npm --prefix ./apps/chatgpt-app-server run dev",
    "app:server:start": "npm --prefix ./apps/chatgpt-app-server run start",
    "app:server:smoke": "node ./scripts/app-shell-smoke.mjs",
    "canvas:test": "node ./apps/chatgpt-app-server/node_modules/tsx/dist/cli.mjs ./scripts/canvas-contract-test.ts",
    "render:prepare-mcphub-config": "node ./scripts/render-prepare-mcphub-config.mjs"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.1",
    "recharts": "^3.8.1",
    "vega-embed": "^7.1.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4"
  }
}
