# App server mode: mock | live
APP_SERVER_MODE=mock

# Public URL where this server is reachable (used in widget metadata)
APP_BASE_URL=http://localhost:8787
PORT=8787

# MCPHub proxy target (used in live mode)
MCPHUB_BASE_URL=http://localhost:8090
MCPHUB_MCP_PATH=/mcp
# Optional auth header value, e.g. "Bearer <token>"
# MCPHUB_AUTH_HEADER=
MCPHUB_TIMEOUT_MS=20000

# Keep write/dangerous pass-through disabled by default
ALLOW_WRITE_THROUGH=false
