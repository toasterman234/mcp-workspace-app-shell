{
  "name": "chatgpt-app-mcp-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Thin ChatGPT Apps MCP layer in front of MCPHub",
  "scripts": {
    "dev": "node ./node_modules/tsx/dist/cli.mjs watch src/server.ts",
    "start": "node ./node_modules/tsx/dist/cli.mjs src/server.ts",
    "build:widget": "./node_modules/.bin/esbuild widget-src/index.tsx --bundle --format=esm --outfile=assets/workspace-widget.js --jsx=automatic",
    "build": "npm run build:widget"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.5.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "esbuild": "^0.25.9",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
